generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// QuickNode Marketplace Add-on Instance
// Supports all 7 Fabrknt products: complr, accredit, sentinel, veil, stratum, tensor, tempest
model QuicknodeInstance {
  id              String   @id @default(cuid())

  // QuickNode identifiers
  quicknodeId     String   @unique
  endpointId      String?
  plan            String   @default("free") // "free" | "starter" | "growth" | "business"

  // Endpoint details
  wssUrl          String?
  httpUrl         String?
  chain           String?
  network         String?

  // Add-on state
  product         String   @default("complr") // "complr" | "accredit" | "sentinel" | "veil" | "stratum" | "tensor" | "tempest"
  apiKey          String   @unique @default(cuid())
  status          String   @default("active") // "active" | "deactivated" | "deprovisioned"

  // Usage tracking
  requestCount    Int      @default(0)
  lastRequestAt   DateTime?

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([quicknodeId])
  @@index([endpointId])
  @@index([status])
  @@index([apiKey])
}
